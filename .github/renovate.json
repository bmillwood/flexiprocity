{
    "extends": [
        "config:recommended",
        "helpers:pinGitHubActionDigestsToSemver"
    ],
    "pinDigests": true,
    "customManagers": [
        {
            "customType": "regex",
            "description": "Update *[-_]version parameters",
            "managerFilePatterns": [".github/workflows/*"],
            "matchStrings": [
                "[-_]version:\\s*(?<currentValue>[0-9.]+)\\s*# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)",
                "[-_]version:\\s*(?<currentDigest>[a-f0-9]{40})\\s*# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+) packageName=(?<packageName>\\S+) currentValue=(?<currentValue>\\S+)"
            ]
        }
    ],
    // Per https://github.com/haskell-actions/setup/blob/main/docs/examples.md#dependency-updates
    // lightly modified to taste
    "commitBody": "{{#each upgrades}}New-{{{datasource}}}-version: {{{depName}}}=={{{newVersion}}}\n{{/each}}"
}
